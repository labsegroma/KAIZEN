<resources xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.KAI" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/kai_primary</item>
        <item name="colorPrimaryVariant">@color/kai_primary_variant</item>
        <item name="colorOnPrimary">@color/kai_on_primary</item>
        <!-- Icono de navegación personalizado -->
        <item name="homeAsUpIndicator">@drawable/volver_ico</item>
        <item name="android:homeAsUpIndicator">@drawable/volver_ico</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/kai_accent</item>
        <item name="colorSecondaryVariant">@color/kai_accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- Aumentar escala tipográfica global -->
        <item name="textAppearanceHeadline6">@style/BigHeadline6</item>
        <item name="textAppearanceSubtitle1">@style/BigSubtitle1</item>
        <item name="textAppearanceSubtitle2">@style/BigSubtitle2</item>
        <item name="textAppearanceBody1">@style/BigBody1</item>
        <item name="textAppearanceBody2">@style/BigBody2</item>
    </style>

    <style name="Theme.KAI.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.KAI.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.KAI.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="NavActiveText" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textColor">@color/kai_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="NavInactiveText" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textColor">@color/kai_text_main</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!-- Definición de los nuevos tamaños de fuente -->
    <style name="BigHeadline6" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">22sp</item>
    </style>

    <style name="BigSubtitle1" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">18sp</item>
    </style>

    <style name="BigSubtitle2" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textSize">16sp</item>
    </style>

    <style name="BigBody1" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">18sp</item>
    </style>

    <style name="BigBody2" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">16sp</item>
    </style>
</resources>