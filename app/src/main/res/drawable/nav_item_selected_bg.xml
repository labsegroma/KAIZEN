<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <layer-list>
            <!-- Fondo sutil con bordes redondeados -->
            <item android:left="8dp" android:right="8dp" android:top="2dp" android:bottom="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/kai_primary_very_soft" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
            <!-- Indicador lateral firme de 6dp -->
            <item android:gravity="start" android:width="6dp" android:top="10dp" android:bottom="10dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/kai_primary" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_checked="false" android:drawable="@android:color/transparent" />
</selector>
