<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_saludo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_top_toTopOf="parent"
        tools:text="Hola, Usuario!"/>

    <TextView
        android:id="@+id/tv_estado_kai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_top_toBottomOf="@id/tv_saludo"
        tools:text="Kai esta feliz"/>

    <TextView
        android:id="@+id/tv_xp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_top_toBottomOf="@id/tv_estado_kai"
        tools:text="XP Total: 1500"/>

    <TextView
        android:id="@+id/tv_racha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_top_toBottomOf="@id/tv_xp"
        tools:text="Racha: 5 dias"/>

    <TextView
        android:id="@+id/tv_titulo_lista"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/titulo_habitos_hoy"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_top_toBottomOf="@id/tv_racha"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_habitos_hoy"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_titulo_lista"/>

</androidx.constraintlayout.widget.ConstraintLayout>
