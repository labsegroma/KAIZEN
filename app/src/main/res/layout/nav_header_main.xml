<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/kai_header_green"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="32dp"
    android:paddingEnd="24dp"
    android:paddingBottom="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/kai_logo"
            android:adjustViewBounds="true" />

        <ImageView
            android:layout_width="95dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/logo_verde_removebg"
            android:adjustViewBounds="true"
            app:tint="@color/white" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Construye tu mejor versión"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:alpha="1.0"
        android:letterSpacing="0.01" />

    <TextView
        android:id="@+id/tv_nav_user_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Roma Ricchi"
        android:textColor="@color/white"
        android:textSize="19sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/tv_nav_user_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nivel 1"
            android:textColor="@color/white"
            android:alpha="0.9"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" • "
            android:textColor="@color/white"
            android:alpha="0.7" />

        <TextView
            android:id="@+id/tv_nav_user_xp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 XP"
            android:textColor="@color/white"
            android:alpha="0.9"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>
